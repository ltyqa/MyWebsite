---
import "../../styles/global.css";
import DashboardSidebar from "../../components/DashboardSidebar.astro";
import PageTransitions from "../../components/PageTransitions.astro";
import {
  aiUpdateKindLabel,
  aiUpdates,
  formatAiUpdateDate,
  type AiUpdate,
} from "../../data/aiUpdates";
import { renderMarkdown } from "../../lib/markdown";

export function getStaticPaths() {
  return aiUpdates.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: AiUpdate };
const title = entry.titleZh || entry.title;
const summary = entry.summaryZh || entry.summary;
const date = formatAiUpdateDate(entry.publishedAt);
const contentZh = renderMarkdown(entry.contentZh || summary);
const contentEn = renderMarkdown(entry.content || entry.summary);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <PageTransitions />
    <meta name="description" content={summary} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23151a18'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='%23fffaf0'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>{title} | AI 动态</title>
  </head>
  <body class="dashboard-body notes-sketch-body ai-news-body">
    <div class="app-shell">
      <DashboardSidebar active="ai-news" />

      <main class="dashboard-main route-main notes-sketch-main ai-news-article-main">
        <section class="article-hero notes-sketch-article-hero">
          <div class="page-shell article-shell">
            <a class="inline-link" href="/ai-news/">返回 AI 动态</a>
            <p class="note-meta">{entry.product} · {aiUpdateKindLabel(entry.kind)} · {date}</p>
            <h1>{title}</h1>
            <p class="hero-copy">来自 {entry.company} 的官方更新，已整理为站内阅读版本。</p>
            <div class="tag-row">
              <span class="tag">{entry.product}</span>
              <span class="tag">官方动态</span>
            </div>
          </div>
        </section>

        <article class="page-shell article-shell article-body notes-sketch-article ai-news-article">
          <div class="ai-language-toolbar">
            <button
              class="ai-language-toggle"
              type="button"
              data-language="zh"
              aria-label="切换为英文全文"
              aria-pressed="false"
            >
              <span data-language-label="zh">中文</span>
              <i aria-hidden="true">/</i>
              <span data-language-label="en">EN</span>
            </button>
          </div>
          <div class="ai-news-full-content ai-news-language-panel" data-language-panel="zh" set:html={contentZh} />
          <div
            class="ai-news-full-content ai-news-language-panel"
            data-language-panel="en"
            lang="en"
            hidden
            set:html={contentEn}
          />

          <div class="ai-article-source">
            <p>本文内容采集自官方网站，排版和翻译可能与原页面存在差异。</p>
            <a class="ai-source-button" href={entry.url} target="_blank" rel="noreferrer noopener">
              <span>阅读官方全文</span>
              <img src="/images/arrow-right-sketch.svg" alt="" aria-hidden="true" />
            </a>
          </div>
        </article>
      </main>
    </div>
    <script is:inline>
      function bindAiLanguageToggle() {
        const toggle = document.querySelector(".ai-language-toggle");
        if (!(toggle instanceof HTMLButtonElement) || toggle.dataset.bound === "true") return;
        toggle.dataset.bound = "true";
        const panels = [...document.querySelectorAll("[data-language-panel]")];

        function selectLanguage(language) {
          toggle.dataset.language = language;
          toggle.setAttribute("aria-pressed", String(language === "en"));
          toggle.setAttribute("aria-label", language === "zh" ? "切换为英文全文" : "切换为中文全文");
          panels.forEach((panel) => {
            panel.hidden = panel.getAttribute("data-language-panel") !== language;
          });
          localStorage.setItem("ai-news-language", language);
        }

        const preferred = localStorage.getItem("ai-news-language");
        selectLanguage(preferred === "en" ? "en" : "zh");
        toggle.addEventListener("click", () => {
          selectLanguage(toggle.dataset.language === "zh" ? "en" : "zh");
        });
      }

      bindAiLanguageToggle();
      document.addEventListener("astro:page-load", bindAiLanguageToggle);
    </script>
  </body>
</html>
