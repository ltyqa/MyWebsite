---
import "../styles/global.css";
import DashboardSidebar from "../components/DashboardSidebar.astro";
import PageTransitions from "../components/PageTransitions.astro";
import { getGitHubNotes } from "../data/github";
import ScrollDecorations from "../components/ScrollDecorations.astro";

const notes = await getGitHubNotes();
const categories = ["全部", ...Array.from(new Set(notes.map((note) => note.category)))];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <PageTransitions />
    <meta name="description" content="个人中文笔记索引，整理技术实践、工具方法和项目复盘" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23151a18'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='%23fffaf0'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>我的笔记 | 我的个人网站</title>
    <script src="/js/live-site-data.js" defer></script>
  </head>
  <body class="dashboard-body notes-sketch-body">
    <div class="app-shell">
      <DashboardSidebar active="notes" />

      <main class="dashboard-main route-main notes-sketch-main">
        <ScrollDecorations />
        <section class="page-hero notes-sketch-hero">
        <div class="page-shell route-hero-grid">
          <div>
            <span class="eyebrow">笔记目录</span>
            <h1>我的笔记</h1>
            <p class="hero-copy">
              这里读取 MyNote 仓库里的 Markdown，在 Obsidian 里新增笔记并推送到 GitHub 后，网站会在重新构建时同步更新
            </p>
          </div>
          <div class="route-hero-panel">
            <p class="project-meta">笔记统计</p>
            <h3>{notes.length} 篇笔记</h3>
            <p>{categories.length - 1} 个分类</p>
          </div>
        </div>
      </section>

      <section class="section-tight notes-sketch-section">
        <div class="page-shell notes-directory">
          <aside class="note-rail directory-rail" aria-label="笔记分类">
            <div class="note-search">
              <label for="note-search-input">搜索笔记</label>
              <input
                id="note-search-input"
                type="search"
                placeholder="标题、分类或摘要"
                autocomplete="off"
                data-note-search-input
              />
              <p data-note-count>{notes.length} 篇可读笔记</p>
            </div>
            {
              categories.map((category, index) => (
                <button
                  class={index === 0 ? "active" : ""}
                  type="button"
                  aria-pressed={index === 0 ? "true" : "false"}
                  style={index === 0 ? "background: var(--ink); color: var(--paper);" : ""}
                  data-category={category}
                  data-category-index={index}
                >
                  {category}
                </button>
              ))
            }
          </aside>

          <div class="note-list directory-list">
            {
              notes.map((note) => (
                <article
                  class="note-card note-card-large"
                  data-note-category={note.category}
                  data-note-search={`${note.title} ${note.category} ${note.excerpt} ${note.meta}`.toLowerCase()}
                >
                  <p class="note-meta">{note.meta}</p>
                  <h2>{note.title}</h2>
                  <p>{note.excerpt}</p>
                  <div class="tag-row">
                    <span class="tag">{note.category}</span>
                    <span class="tag">Markdown</span>
                  </div>
                  <a class="inline-link" href={note.link}>在网站阅读</a>
                </article>
              ))
            }
          </div>
        </div>
      </section>
      </main>
    </div>

    <script>
      const categoryButtons = document.querySelectorAll("[data-category]");
      const noteCards = document.querySelectorAll("[data-note-category]");
      const noteSearchInput = document.querySelector("[data-note-search-input]");
      const noteCount = document.querySelector("[data-note-count]");
      const activeStyle = "background: var(--ink); color: var(--paper);";
      const idleStyle = "background: transparent; color: var(--muted);";
      let activeCategory = categoryButtons[0]?.getAttribute("data-category") || "";
      let activeCategoryIndex = "0";

      const updateNotes = () => {
        const query = noteSearchInput?.value.trim().toLowerCase() || "";
        let visibleCount = 0;

        noteCards.forEach((card) => {
          const matchesCategory =
            activeCategoryIndex === "0" ||
            card.getAttribute("data-note-category") === activeCategory;
          const matchesQuery = !query || card.getAttribute("data-note-search")?.includes(query);
          const isVisible = matchesCategory && matchesQuery;

          card.toggleAttribute("hidden", !isVisible);
          if (isVisible) visibleCount += 1;
        });

        if (noteCount) {
          noteCount.textContent = query
            ? `${visibleCount} 篇匹配笔记`
            : `${visibleCount} 篇可读笔记`;
        }
      };

      categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeCategory = button.getAttribute("data-category") || "";
          activeCategoryIndex = button.getAttribute("data-category-index") || "0";

          categoryButtons.forEach((item) => {
            item.classList.remove("active");
            item.setAttribute("aria-pressed", "false");
            item.setAttribute("style", idleStyle);
          });
          button.classList.add("active");
          button.setAttribute("aria-pressed", "true");
          button.setAttribute("style", activeStyle);
          updateNotes();
        });
      });

      noteSearchInput?.addEventListener("input", updateNotes);
    </script>
  </body>
</html>
