---
import "../styles/global.css";
import DashboardSidebar from "../components/DashboardSidebar.astro";
import PageTransitions from "../components/PageTransitions.astro";
import { getGitHubNotes } from "../data/github";
import ScrollDecorations from "../components/ScrollDecorations.astro";

const notes = await getGitHubNotes();
const categories = ["全部", ...Array.from(new Set(notes.map((note) => note.category)))];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <PageTransitions />
    <meta name="description" content="个人中文笔记索引，整理技术实践、工具方法和项目复盘" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23151a18'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='%23fffaf0'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>我的笔记 | 我的个人网站</title>
    <script is:inline src="/js/live-site-data.js" defer></script>
  </head>
  <body class="dashboard-body notes-sketch-body">
    <div class="app-shell">
      <DashboardSidebar active="notes" />

      <main class="dashboard-main route-main notes-sketch-main">
        <ScrollDecorations />
        <section class="page-hero notes-sketch-hero">
        <div class="page-shell route-hero-grid">
          <div>
            <span class="eyebrow">笔记目录</span>
            <h1>我的笔记</h1>
            <p class="hero-copy">
              这里读取 MyNote 仓库里的 Markdown，在 Obsidian 里新增笔记并推送到 GitHub 后，网站会在重新构建时同步更新
            </p>
          </div>
          <div class="route-hero-panel">
            <p class="project-meta">笔记统计</p>
            <h3>{notes.length} 篇笔记</h3>
            <p>{categories.length - 1} 个分类</p>
          </div>
        </div>
      </section>

      <section class="section-tight notes-sketch-section">
        <div class="page-shell notes-directory">
          <div class="note-search-panel" role="search" aria-label="搜索笔记">
            <div class="note-search-control">
              <svg viewBox="0 0 32 32" aria-hidden="true">
                <circle cx="13.5" cy="13.5" r="8.5"></circle>
                <path d="m20 20 7 7"></path>
              </svg>
              <input
                id="note-search-input"
                type="search"
                inputmode="search"
                autocomplete="off"
                placeholder="搜索标题、分类或摘要"
                aria-label="搜索笔记"
                aria-controls="note-results"
                data-note-search-input
              />
              <button
                class="note-search-clear"
                type="button"
                aria-label="清除搜索关键词"
                data-note-search-clear
                hidden
              >
                清除
              </button>
            </div>
            <div class="note-search-summary">
              <p data-note-result-count aria-live="polite">共 {notes.length} 篇</p>
              <span aria-hidden="true">Ctrl / ⌘ K</span>
            </div>
          </div>

          <aside class="note-rail directory-rail" aria-label="笔记分类">
            {
              categories.map((category, index) => (
                <button
                  class={index === 0 ? "active" : ""}
                  type="button"
                  aria-pressed={index === 0 ? "true" : "false"}
                  data-category={category}
                >
                  {category}
                </button>
              ))
            }
          </aside>

          <div class="note-list directory-list" id="note-results">
            {
              notes.map((note) => (
                <article
                  class="note-card note-card-large"
                  data-note-category={note.category}
                  data-note-search={`${note.title} ${note.category} ${note.excerpt} ${note.meta}`}
                >
                  <p class="note-meta">{note.meta}</p>
                  <h2>{note.title}</h2>
                  <p>{note.excerpt}</p>
                  <div class="tag-row">
                    <span class="tag">{note.category}</span>
                    <span class="tag">Markdown</span>
                  </div>
                  <a class="inline-link" href={note.link}>在网站阅读</a>
                </article>
              ))
            }
            <div class="note-empty-state" data-note-empty-state hidden>
              <p class="poster-kicker">没有匹配结果</p>
              <h2>换个关键词试试</h2>
              <p>当前关键词和分类下没有找到笔记，可以清除筛选后重新浏览。</p>
              <button type="button" data-note-filter-reset>清除筛选</button>
            </div>
          </div>
        </div>
      </section>
      </main>
    </div>

    <script is:inline data-astro-rerun>
      (() => {
        window.__notesSearchCleanup?.();

        const cleanupTasks = [];
        window.__notesSearchCleanup = () => {
          cleanupTasks.splice(0).forEach((cleanup) => cleanup());
        };

        const searchInput = document.querySelector("[data-note-search-input]");
        const clearButton = document.querySelector("[data-note-search-clear]");
        const resetButton = document.querySelector("[data-note-filter-reset]");
        const resultCount = document.querySelector("[data-note-result-count]");
        const emptyState = document.querySelector("[data-note-empty-state]");
        const noteList = document.querySelector("#note-results");
        const categoryButtons = Array.from(document.querySelectorAll("[data-category]"));
        const noteCards = Array.from(document.querySelectorAll("[data-note-category]"));

        if (!searchInput || !clearButton || !resetButton || !resultCount || !emptyState || !noteList) {
          return;
        }

        let activeCategory = "全部";

        const normalize = (value) => value.trim().toLocaleLowerCase("zh-CN");
        const setActiveCategory = (category) => {
          activeCategory = category || "全部";
          categoryButtons.forEach((button) => {
            const isActive = button.getAttribute("data-category") === activeCategory;
            button.classList.toggle("active", isActive);
            button.setAttribute("aria-pressed", String(isActive));
          });
        };

        const applyFilters = () => {
          const normalizedQuery = normalize(searchInput.value);
          const queryTokens = normalizedQuery.split(/\s+/).filter(Boolean);
          let visibleCount = 0;

          noteCards.forEach((card) => {
            const matchesCategory =
              activeCategory === "全部" ||
              card.getAttribute("data-note-category") === activeCategory;
            const searchValue = normalize(card.getAttribute("data-note-search") || "");
            const matchesQuery = queryTokens.every((token) => searchValue.includes(token));
            const isVisible = matchesCategory && matchesQuery;

            card.toggleAttribute("hidden", !isVisible);
            if (isVisible) visibleCount += 1;
          });

          const isDefaultView = activeCategory === "全部" && queryTokens.length === 0;
          resultCount.textContent = isDefaultView
            ? `共 ${noteCards.length} 篇`
            : `找到 ${visibleCount} 篇`;
          clearButton.toggleAttribute("hidden", searchInput.value.length === 0);
          emptyState.toggleAttribute("hidden", visibleCount !== 0);
          noteList.classList.toggle("is-empty", visibleCount === 0);
        };

        const handleSearchInput = () => applyFilters();
        searchInput.addEventListener("input", handleSearchInput);
        cleanupTasks.push(() => searchInput.removeEventListener("input", handleSearchInput));

        categoryButtons.forEach((button) => {
          const handleCategoryClick = () => {
            setActiveCategory(button.getAttribute("data-category"));
            applyFilters();
          };
          button.addEventListener("click", handleCategoryClick);
          cleanupTasks.push(() => button.removeEventListener("click", handleCategoryClick));
        });

        const handleClearSearch = () => {
          searchInput.value = "";
          applyFilters();
          searchInput.focus();
        };
        clearButton.addEventListener("click", handleClearSearch);
        cleanupTasks.push(() => clearButton.removeEventListener("click", handleClearSearch));

        const handleResetFilters = () => {
          searchInput.value = "";
          setActiveCategory("全部");
          applyFilters();
          searchInput.focus();
        };
        resetButton.addEventListener("click", handleResetFilters);
        cleanupTasks.push(() => resetButton.removeEventListener("click", handleResetFilters));

        const handleKeyboardShortcut = (event) => {
          const key = event.key.toLocaleLowerCase();
          if ((event.ctrlKey || event.metaKey) && key === "k") {
            event.preventDefault();
            searchInput.focus();
            searchInput.select();
            return;
          }

          if (event.key === "Escape" && document.activeElement === searchInput) {
            searchInput.value = "";
            applyFilters();
          }
        };
        document.addEventListener("keydown", handleKeyboardShortcut);
        cleanupTasks.push(() => document.removeEventListener("keydown", handleKeyboardShortcut));

        const handleBeforeSwap = () => window.__notesSearchCleanup?.();
        document.addEventListener("astro:before-swap", handleBeforeSwap, { once: true });
        cleanupTasks.push(() => document.removeEventListener("astro:before-swap", handleBeforeSwap));

        setActiveCategory("全部");
        applyFilters();
      })();
    </script>
  </body>
</html>
