---
import "../styles/global.css";
import { getGitHubNotes } from "../data/github";

const notes = await getGitHubNotes();
const categories = ["全部", ...Array.from(new Set(notes.map((note) => note.category)))];
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="个人中文笔记索引，整理技术实践、工具方法和项目复盘。" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23151a18'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='%23fffaf0'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>笔记 | 我的个人网站</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav page-shell" aria-label="主导航">
        <a class="brand" href="/" aria-label="回到首页">
          <span class="brand-mark">站</span>
          <span>个人档案</span>
        </a>
        <div class="nav-links">
          <a href="/projects/">项目</a>
          <a href="/notes/">笔记</a>
          <a href="/#github">活跃</a>
          <a href="/#about">关于</a>
        </div>
      </nav>
    </header>

    <main>
      <section class="page-hero">
        <div class="page-shell route-hero-grid">
          <div>
            <span class="eyebrow">笔记目录</span>
            <h1>把问题背后的判断，<span>留下来。</span></h1>
            <p class="hero-copy">
              这里会读取 MyNote 仓库里的 Markdown。以后你在 Obsidian 里新增笔记并推送到 GitHub，网站重新构建后就会出现在这里。
            </p>
          </div>
          <div class="route-hero-panel code-window">
            <code>notes / methods / deployment<br />整理判断，而不是堆积摘录<br />保持短、清楚、可复用</code>
          </div>
        </div>
      </section>

      <section class="section-tight">
        <div class="page-shell notes-directory">
          <aside class="note-rail directory-rail" aria-label="笔记分类">
            {categories.map((category) => <a href="/notes/">{category}</a>)}
          </aside>

          <div class="note-list directory-list">
            {
              notes.map((note) => (
                <article class="note-card note-card-large">
                  <p class="note-meta">{note.meta}</p>
                  <h2>{note.title}</h2>
                  <p>{note.excerpt}</p>
                  <div class="tag-row">
                    <span class="tag">{note.category}</span>
                    <span class="tag">Markdown</span>
                  </div>
                  <a class="inline-link" href={note.link}>在网站阅读</a>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
