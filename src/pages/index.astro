---
import "../styles/global.css";
import { timeline } from "../data/content";
import {
  getGitHubActivities,
  getGitHubNotes,
  getGitHubProjects,
} from "../data/github";

const projects = await getGitHubProjects();
const notes = await getGitHubNotes();
const activities = await getGitHubActivities();
const latestProjects = projects.slice(0, 2);
const latestNotes = notes.slice(0, 3);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="一个展示项目、笔记和近期动态的中文个人网站。" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23151a18'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='%23fffaf0'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>我的个人网站 | 首页</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav page-shell" aria-label="主导航">
        <a class="brand" href="/" aria-label="回到首页">
          <span class="brand-mark">站</span>
          <span>个人档案</span>
        </a>
        <div class="nav-links">
          <a href="/projects/">项目</a>
          <a href="/notes/">笔记</a>
          <a href="/#github">活跃</a>
          <a href="/#about">关于</a>
        </div>
      </nav>
    </header>

    <main id="top">
      <section class="hero home-hero">
        <div class="page-shell hero-grid">
          <div>
            <span class="eyebrow">项目、笔记和近况</span>
            <h1>把正在做的事，<span>整理成清楚的档案。</span></h1>
            <p class="hero-copy">
              这里记录我做过的小工具、正在整理的想法，以及最近留下的工作痕迹。少一点装饰，多一点能被再次打开的内容。
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="#github">查看近况</a>
              <a class="button button-secondary" href="/projects/">浏览作品</a>
            </div>
          </div>

          <div class="home-dashboard" aria-label="站点核心状态">
            <article class="status-card status-card-strong">
              <p class="project-meta">当前整理</p>
              <h2>{projects.length} 件作品，{notes.length} 篇札记</h2>
              <p>内容来自 GitHub 仓库，每次重新构建都会刷新到最新状态。</p>
            </article>
            <article class="status-card">
              <p class="project-meta">最近更新</p>
              <h3>{activities[0]?.[1] || "同步中"}</h3>
              <p>{activities[0]?.[2] || "等待下一次仓库更新。"}</p>
            </article>
            <article class="status-card accent-card">
              <p class="project-meta">同步来源</p>
              <h3>MyWebsite + MyNote</h3>
              <p>项目来自 GitHub 公开仓库，笔记来自 MyNote 的 Markdown 文件。</p>
            </article>
          </div>
        </div>
      </section>

      <section id="github" class="section sync-section">
        <div class="page-shell activity-layout">
          <div class="section-heading">
            <span class="section-kicker">最近近况</span>
            <h2>先看最近发生了什么。</h2>
            <p>
              首页不堆满内容，只留下近期最值得看的变化：更新了什么、写了什么、还在打磨什么。
            </p>
          </div>

          <div class="activity-feed">
            {
              activities.map(([time, title, body]) => (
                <article class="activity-item">
                  <p class="timeline-date">{time}</p>
                  <div>
                    <h3>{title}</h3>
                    <p>{body}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section">
        <div class="page-shell split-preview">
          <div class="section-heading">
            <span class="section-kicker">作品节选</span>
            <h2>挑几件能代表方向的作品。</h2>
            <p>完整清单放在项目页，这里只保留最适合作为入口的两件。</p>
            <div class="section-actions">
              <a class="button button-primary" href="/projects/">查看全部作品</a>
            </div>
          </div>

          <div class="compact-list">
            {
              latestProjects.map((project) => (
                <article class="mini-project">
                  <div>
                    <p class="project-meta">{project.meta}</p>
                    <h3>{project.name}</h3>
                    <p>{project.description}</p>
                  </div>
                  <div class="tag-row">
                    {project.stack.map((item) => <span class="tag">{item}</span>)}
                  </div>
                  <a class="inline-link" href={project.link} target="_blank" rel="noreferrer">打开仓库</a>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section-tight">
        <div class="page-shell split-preview reverse">
          <div class="compact-list">
            {
              latestNotes.map((note) => (
                <article class="note-card">
                  <p class="note-meta">{note.meta}</p>
                  <h3>{note.title}</h3>
                  <p>{note.excerpt}</p>
                  {"link" in note && (
                    <a class="inline-link" href={note.link} target="_blank" rel="noreferrer">阅读原文</a>
                  )}
                </article>
              ))
            }
          </div>

          <div class="section-heading">
            <span class="section-kicker">近期笔记</span>
            <h2>把想明白的事写下来。</h2>
            <p>这些不是完整教程，更像工作中留下的判断、取舍和复盘。</p>
            <div class="section-actions">
              <a class="button button-primary" href="/notes/">查看全部笔记</a>
            </div>
          </div>
        </div>
      </section>

      <section id="about" class="section">
        <div class="page-shell about-layout">
          <article class="about-portrait">
            <p class="project-meta">关于这里</p>
            <h2>一份慢慢生长的工作档案。</h2>
            <p>
              记录项目，也记录过程。比起一次性写完，我更希望它能持续变得清楚。
            </p>
          </article>

          <div class="timeline">
            {
              timeline.map(([date, title, body]) => (
                <article class="timeline-card">
                  <p class="timeline-date">{date}</p>
                  <div>
                    <h3>{title}</h3>
                    <p>{body}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="page-shell footer-grid">
        <div>
          <strong>个人档案</strong>
          <p>项目、笔记和近况会在这里持续更新。</p>
        </div>
        <div>
          <strong>项目</strong>
          <a href="/projects/">全部作品</a>
          <a href="/#github">最近近况</a>
        </div>
        <div>
          <strong>笔记</strong>
          <a href="/notes/">全部笔记</a>
          <a href="/notes/">分类索引</a>
        </div>
        <div>
          <strong>联系</strong>
          <a href="https://github.com/" target="_blank" rel="noreferrer">GitHub</a>
          <a href="mailto:hello@example.com">Email</a>
        </div>
      </div>
    </footer>
  </body>
</html>
