---
import "../styles/global.css";
import { timeline } from "../data/content";
import {
  getGitHubActivities,
  getGitHubActivityChart,
  getGitHubNotes,
  getGitHubProjects,
} from "../data/github";

const projects = await getGitHubProjects();
const notes = await getGitHubNotes();
const activities = await getGitHubActivities();
const activityChart = await getGitHubActivityChart();
const latestProjects = projects.slice(0, 4);
const latestNotes = notes.slice(0, 5);
const latestActivity = activities[0];
const activeProjectCount = projects.filter((project) => project.status === "维护中").length || projects.length;
const categories = Array.from(new Set(notes.map((note) => note.category))).slice(0, 6);
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="由 GitHub 自动同步的个人项目、笔记和近期动态仪表盘。" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%232f6fed'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='white'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>个人档案 | 首页</title>
  </head>
  <body class="dashboard-body">
    <div class="app-shell">
      <aside class="sidebar" aria-label="主导航">
        <a class="brand brand-dashboard" href="/" aria-label="回到首页">
          <span class="brand-mark">站</span>
          <span>个人档案</span>
        </a>

        <nav class="side-nav">
          <a class="active" href="/">
            <span class="nav-icon">⌂</span>
            首页
          </a>
          <a href="/projects/">
            <span class="nav-icon">▦</span>
            项目
          </a>
          <a href="/notes/">
            <span class="nav-icon">◇</span>
            笔记
          </a>
          <a href="#github">
            <span class="nav-icon">↗</span>
            活跃记录
          </a>
          <a href="#about">
            <span class="nav-icon">●</span>
            关于
          </a>
        </nav>

        <div class="sidebar-card">
          <p class="project-meta">同步来源</p>
          <strong>MyWebsite + MyNote</strong>
          <span>每次推送后自动整理成静态页面。</span>
        </div>
      </aside>

      <main class="dashboard-main">
        <header class="dashboard-topbar">
          <div>
            <p class="project-meta">Dashboard</p>
            <h1>最近在做什么，先放在首页。</h1>
          </div>

          <div class="topbar-actions">
            <label class="search-box">
              <span>⌕</span>
              <input type="search" placeholder="搜索项目或笔记..." aria-label="搜索项目或笔记" />
            </label>
            <a class="checkin" href="#github">
              <span></span>
              自动同步中
            </a>
          </div>
        </header>

        <section class="metric-grid" aria-label="站点概览">
          <article class="metric-card">
            <div class="metric-head">
              <span class="metric-icon cool">▦</span>
              <p>项目</p>
            </div>
            <strong>{projects.length}</strong>
            <span class="metric-note">来自 GitHub 仓库</span>
          </article>

          <article class="metric-card">
            <div class="metric-head">
              <span class="metric-icon green">◇</span>
              <p>笔记</p>
            </div>
            <strong>{notes.length}</strong>
            <span class="metric-note">来自 MyNote Markdown</span>
          </article>

          <article class="metric-card">
            <div class="metric-head">
              <span class="metric-icon coral">↗</span>
              <p>维护中</p>
            </div>
            <strong>{activeProjectCount}</strong>
            <span class="metric-note">近期仍有更新</span>
          </article>

          <article class="metric-card">
            <div class="metric-head">
              <span class="metric-icon violet">⌁</span>
              <p>最新动态</p>
            </div>
            <strong>{latestActivity?.[0] || "今日"}</strong>
            <span class="metric-note">{latestActivity?.[1] || "等待同步"}</span>
          </article>
        </section>

        <section class="dashboard-grid" id="github">
          <article class="panel panel-large">
            <div class="panel-head">
              <div>
                <p class="project-meta">活跃记录</p>
                <h2>最近更新</h2>
              </div>
              <a class="panel-link" href="/projects/">查看项目</a>
            </div>

            <div class="activity-chart" aria-label="最近 21 天 GitHub 提交统计">
              {
                activityChart.map((day) => (
                  <div
                    class={`chart-bar ${day.count === 0 ? "is-empty" : ""}`}
                    title={`${day.label}: ${day.count} 次更新，网站 ${day.website} 次，笔记 ${day.notes} 次`}
                  >
                    <span style={`height: ${day.height}%`}></span>
                    <small>{day.label}</small>
                  </div>
                ))
              }
            </div>

            <div class="activity-feed compact-feed">
              {
                activities.map(([time, title, body]) => (
                  <article class="activity-item">
                    <p class="timeline-date">{time}</p>
                    <div>
                      <h3>{title}</h3>
                      <p>{body}</p>
                    </div>
                  </article>
                ))
              }
            </div>
          </article>

          <article class="panel">
            <div class="panel-head">
              <div>
                <p class="project-meta">项目入口</p>
                <h2>正在维护</h2>
              </div>
              <a class="panel-link" href="/projects/">全部</a>
            </div>

            <div class="dashboard-list">
              {
                latestProjects.map((project) => (
                  <a class="list-row" href={project.link} target="_blank" rel="noreferrer">
                    <span class="row-icon">▣</span>
                    <span>
                      <strong>{project.name}</strong>
                      <small>{project.description}</small>
                    </span>
                    <em>{project.status}</em>
                  </a>
                ))
              }
            </div>
          </article>

          <article class="panel note-panel">
            <div class="panel-head">
              <div>
                <p class="project-meta">笔记阅读</p>
                <h2>最近整理</h2>
              </div>
              <a class="panel-link" href="/notes/">全部</a>
            </div>

            <div class="note-dashboard-list">
              {
                latestNotes.map((note) => (
                  <a class="note-row" href={note.link}>
                    <strong>{note.title}</strong>
                    <span>{note.category} / {note.meta.split("/").pop()?.trim()}</span>
                  </a>
                ))
              }
            </div>
          </article>

          <article class="panel">
            <div class="panel-head">
              <div>
                <p class="project-meta">分类</p>
                <h2>笔记分布</h2>
              </div>
            </div>

            <div class="category-cloud">
              {categories.map((category) => <a href="/notes/">{category}</a>)}
            </div>
          </article>
        </section>

        <section class="dashboard-grid lower-grid" id="about">
          <article class="panel profile-panel">
            <p class="project-meta">关于这个网站</p>
            <h2>它更像一个可更新的工作台。</h2>
            <p>
              项目负责展示能打开的成果，笔记负责保存当时的判断和方法。首页只保留最重要的状态，让你一眼知道最近发生了什么。
            </p>
          </article>

          <article class="panel timeline-panel">
            <div class="panel-head">
              <div>
                <p class="project-meta">路线</p>
                <h2>下一步</h2>
              </div>
            </div>
            <div class="timeline">
              {
                timeline.map(([date, title, body]) => (
                  <article class="timeline-card">
                    <p class="timeline-date">{date}</p>
                    <div>
                      <h3>{title}</h3>
                      <p>{body}</p>
                    </div>
                  </article>
                ))
              }
            </div>
          </article>
        </section>
      </main>
    </div>
  </body>
</html>
