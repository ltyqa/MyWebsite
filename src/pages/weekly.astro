---
import { marked } from "marked";
import "../styles/global.css";
import DashboardSidebar from "../components/DashboardSidebar.astro";
import PageTransitions from "../components/PageTransitions.astro";
import WeeklyReviewPanel from "../components/WeeklyReviewPanel.astro";
import { getLatestWeeklyIssue } from "../data/weekly";
import {
  extractWeeklyReviewLinks,
  proxyWeeklyImages,
  removeWeeklyReviewSection,
  stripWeeklyTitle,
} from "../data/weeklyContent";

const issue = await getLatestWeeklyIssue();
const articleMarkdown = removeWeeklyReviewSection(stripWeeklyTitle(issue.markdown));
const reviewLinks = extractWeeklyReviewLinks(issue.markdown);

const content = marked.parse(proxyWeeklyImages(articleMarkdown), {
  async: false,
  gfm: true,
  breaks: false,
});
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <PageTransitions />
    <meta name="description" content={`来自 ruanyf/weekly 的最新一期：${issue.title}`} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%23151a18'/%3E%3Ctext x='32' y='42' text-anchor='middle' font-size='30' font-family='Arial,sans-serif' fill='%23fffaf0'%3E%E7%AB%99%3C/text%3E%3C/svg%3E" />
    <title>每周新闻 | {issue.title}</title>
    <script src="/js/live-site-data.js" defer></script>
  </head>
  <body class="dashboard-body notes-sketch-body weekly-news-body">
    <div class="app-shell">
      <DashboardSidebar active="weekly" />

      <main class="dashboard-main route-main notes-sketch-main weekly-news-main">
        <section class="page-hero projects-sketch-hero weekly-news-hero">
          <div class="page-shell route-hero-grid">
            <div>
              <span class="eyebrow">每周新闻</span>
              <h1>开源周刊</h1>
              <p class="hero-copy">{issue.title}</p>
              <a class="weekly-source-link" href={issue.sourceUrl} target="_blank" rel="noreferrer">
                查看来源文件
              </a>
            </div>
            <div class="route-hero-panel">
              <p class="project-meta">本期信息</p>
              <h3>第 {issue.number} 期</h3>
              <p>发布于 {issue.publishedLabel}</p>
            </div>
          </div>
        </section>

        <article class="page-shell article-shell article-body notes-sketch-article weekly-news-article" set:html={content} />
        <WeeklyReviewPanel links={reviewLinks} />
      </main>
    </div>
  </body>
</html>
