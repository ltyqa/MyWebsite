---
import { siteNavigation, type SiteNavKey } from "../data/navigation";
import AppearanceSettings from "./AppearanceSettings.astro";

type Props = {
  active?: SiteNavKey;
};

const { active = "home" } = Astro.props;
---

<aside class="sidebar" aria-label="主导航">
  <a class="brand brand-dashboard" href="/?skipIntro=1" aria-label="回到首页">
    <span class="brand-mark">
      <img src="/images/icon-site.svg" alt="" aria-hidden="true" />
    </span>
    <span>个人博客</span>
  </a>

  <nav class="side-nav">
    {
      siteNavigation.map((item) => (
        <a class={active === item.key ? "active" : ""} href={item.href}>
          <span class="nav-icon">
            <img src={item.icon} alt="" aria-hidden="true" />
          </span>
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="sidebar-card">
    <p class="project-meta">本站内容</p>
    <strong>项目 · 笔记 · 周刊</strong>
    <span>记录开发实践，整理学习笔记与 AI 动态</span>
  </div>

  <AppearanceSettings />
</aside>

<script is:inline data-astro-rerun>
  (() => {
    window.__dashboardSidebarCleanup?.();

    const cleanupTasks = [];
    window.__dashboardSidebarCleanup = () => {
      cleanupTasks.splice(0).forEach((cleanup) => cleanup());
    };

    const prepareHomeRoomDocument = (doc) => {
      doc.documentElement.classList.add("skip-home-intro");
      doc.querySelector("[data-experience]")?.classList.add("is-loaded", "is-room-open");

      const progress = doc.querySelector("[data-loader-progress]");
      if (progress) progress.textContent = "100%";
    };

    const markHomeNavigation = (event) => {
      const link = event.target?.closest?.('a[href^="/?skipIntro=1"]');
      if (!link) return;

      window.__isEnteringHomeRoom = true;
      document.documentElement.classList.add("skip-home-intro", "is-entering-home-room");
      sessionStorage.setItem("homeIntroSeen", "1");
    };

    const handleBeforeSwap = (event) => {
      if (!window.__isEnteringHomeRoom || !event.newDocument) return;
      prepareHomeRoomDocument(event.newDocument);
    };

    document.addEventListener("pointerdown", markHomeNavigation, { capture: true });
    document.addEventListener("click", markHomeNavigation, { capture: true });
    document.addEventListener("astro:before-swap", handleBeforeSwap);
    cleanupTasks.push(() => document.removeEventListener("pointerdown", markHomeNavigation, { capture: true }));
    cleanupTasks.push(() => document.removeEventListener("click", markHomeNavigation, { capture: true }));
    cleanupTasks.push(() => document.removeEventListener("astro:before-swap", handleBeforeSwap));

    const clearHomeNavigation = () => {
      window.__isEnteringHomeRoom = false;
      document.documentElement.classList.remove("is-entering-home-room");
    };
    document.addEventListener("astro:page-load", clearHomeNavigation, { once: true });
    cleanupTasks.push(() => document.removeEventListener("astro:page-load", clearHomeNavigation));

    if (window.matchMedia("(max-width: 980px)").matches) {
      document.querySelector(".side-nav a.active")?.scrollIntoView({
        block: "nearest",
        inline: "nearest",
      });
    }
  })();
</script>
