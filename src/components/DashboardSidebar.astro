---
type Props = {
  active?: "home" | "projects" | "notes" | "activity";
};

const { active = "home" } = Astro.props;
---

<aside class="sidebar" aria-label="主导航">
  <a class="brand brand-dashboard" href="/" aria-label="回到首页">
    <span class="brand-mark">站</span>
    <span>个人档案</span>
  </a>

  <nav class="side-nav">
    <a class={active === "home" ? "active" : ""} href="/">
      <span class="nav-icon">⌂</span>
      首页
    </a>
    <a class={active === "projects" ? "active" : ""} href="/projects/">
      <span class="nav-icon">▦</span>
      项目
    </a>
    <a class={active === "notes" ? "active" : ""} href="/notes/">
      <span class="nav-icon">◇</span>
      笔记
    </a>
    <a class={active === "activity" ? "active" : ""} href="/#github">
      <span class="nav-icon">↗</span>
      活跃记录
    </a>
  </nav>

  <div class="sidebar-card">
    <p class="project-meta">同步来源</p>
    <strong>MyWebsite + MyNote</strong>
    <span>推送后自动整理成静态页面</span>
  </div>
</aside>
