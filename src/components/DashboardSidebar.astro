---
type Props = {
  active?: "home" | "projects" | "notes" | "activity" | "about";
};

const { active = "home" } = Astro.props;
---

<aside class="sidebar" aria-label="主导航">
  <a class="brand brand-dashboard" href="/?skipIntro=1" aria-label="回到首页">
    <span class="brand-mark">
      <img src="/images/icon-site.svg" alt="" aria-hidden="true" />
    </span>
    <span>个人档案</span>
  </a>

  <nav class="side-nav">
    <a class={active === "home" ? "active" : ""} href="/?skipIntro=1">
      <span class="nav-icon">
        <img src="/images/icon-home.svg" alt="" aria-hidden="true" />
      </span>
      首页
    </a>
    <a class={active === "projects" ? "active" : ""} href="/projects/">
      <span class="nav-icon">
        <img src="/images/icon-projects.svg" alt="" aria-hidden="true" />
      </span>
      项目
    </a>
    <a class={active === "notes" ? "active" : ""} href="/notes/">
      <span class="nav-icon">
        <img src="/images/icon-notes.svg" alt="" aria-hidden="true" />
      </span>
      笔记
    </a>
    <a class={active === "about" ? "active" : ""} href="/about/">
      <span class="nav-icon">
        <img src="/images/icon-about.svg" alt="" aria-hidden="true" />
      </span>
      作者信息
    </a>
    <a class={active === "activity" ? "active" : ""} href="/?skipIntro=1#room">
      <span class="nav-icon">
        <img src="/images/icon-activity.svg" alt="" aria-hidden="true" />
      </span>
      活跃记录
    </a>
  </nav>

  <div class="sidebar-card">
    <p class="project-meta">同步来源</p>
    <strong>MyWebsite + MyNote</strong>
    <span>推送后自动整理成静态页面</span>
  </div>
</aside>

<script>
  document.querySelector(".side-nav a.active")?.scrollIntoView({
    block: "nearest",
    inline: "center",
  });
</script>
